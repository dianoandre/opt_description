<?xml version="1.0"?>

<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

    <material name="red_material">
        <color rgba="1 0 0 1" />
    </material>
    <material name="green_material">
        <color rgba="0 1 0 1" />
    </material>
    <material name="blue_material">
        <color rgba="0 0 1 1" />
    </material>
    <material name="yellow_material">
        <color rgba="1 1 0 1" />
    </material>


    <xacro:macro name="opt_table">

        <xacro:property name="visual_seat"
            value="file://$(find opt_description)/meshes/visual/seat.stl" />
        <xacro:property name="visual_backrest"
            value="file://$(find opt_description)/meshes/visual/backrest.stl" />
        <xacro:property name="visual_support"
            value="file://$(find opt_description)/meshes/visual/support.stl" />
        <xacro:property name="visual_base"
            value="file://$(find opt_description)/meshes/visual/base.stl" />

        <xacro:property name="collision_central"
            value="file://$(find opt_description)/meshes/collision/nuova_centrale.dae" />
        <xacro:property name="collision_superior"
            value="file://$(find opt_description)/meshes/collision/nuova_superiore.dae" />
        <xacro:property name="collision_mezzo"
            value="file://$(find opt_description)/meshes/collision/mezzo.dae" />
        <xacro:property name="collision_base"
            value="file://$(find opt_description)/meshes/collision/nuova_base_dec.dae" />

        <xacro:property name="meshscale" value="0.01 0.01 0.01" />

        <link name="world" />

        <link name="base_link">
            <visual>
                <origin xyz="0.273417 -0.470138 0.034228" rpy="0 0 0" />
                <geometry>
                    <mesh filename="${visual_base}" scale="${meshscale}" />
                </geometry>
                <material name="red_material" />
            </visual>
            <!-- <collision>
                <origin xyz="0.273417 -0.470138 0.034228" rpy="0 0 0" />
                <geometry>
                    <mesh filename="${visual_base}" scale="${meshscale}" />
                </geometry>
            </collision> -->
            <inertial>
                <mass value="10" />
                <origin xyz="0 0 0" rpy="0 0 0" />
                <inertia ixx="1" ixy="0" ixz="0" iyy="1" iyz="0" izz="1" />
            </inertial>
        </link>

        <link name="support_link">
            <visual>
                <origin xyz="0.305417 -0.524138 -0.521772" rpy="0 0 0" />
                <geometry>
                    <mesh filename="${visual_support}" scale="${meshscale}" />
                </geometry>
                <material name="blue_material" />
            </visual>
            <!-- <collision>
                <origin xyz="0.305417 -0.524138 -0.521772" rpy="0 0 0" />
                <geometry>
                    <mesh filename="${collision_mezzo}" scale="${meshscale}" />
                </geometry>
            </collision> -->
            <inertial>
                <mass value="1" />
                <origin xyz="0 0 0" rpy="0 0 0" />
                <inertia ixx="1" ixy="0" ixz="0" iyy="1" iyz="0" izz="1" />
            </inertial>
        </link>


        <link name="seat_rot_y_link">
            <!-- <collision>
                <origin xyz="0 0 0" rpy="0 0 0" />
                <geometry>
                    <box size="0.1 0.1 0.1" />
                </geometry>
            </collision> -->
            <inertial>
                <mass value="1" />
                <origin xyz="0 0 0" rpy="0 0 0" />
                <inertia ixx="1" ixy="0" ixz="0" iyy="1" iyz="0" izz="1" />
            </inertial>
        </link>


        <link name="seat_rot_x_link">
            <!-- <collision>
                <origin xyz="0 0 0" rpy="0 0 0" />
                <geometry>
                    <box size="0.1 0.1 0.1" />
                </geometry>
            </collision> -->
            <inertial>
                <mass value="1" />
                <origin xyz="0 0 0" rpy="0 0 0" />
                <inertia ixx="1" ixy="0" ixz="0" iyy="1" iyz="0" izz="1" />
            </inertial>
        </link>


        <link name="seat_link">
            <visual>
                <origin xyz="0.305417 -0.524138 -0.646947" rpy="0 0 0" />
                <geometry>
                    <mesh filename="${visual_seat}" scale="${meshscale}" />
                </geometry>
                <material name="green_material" />
            </visual>
            <!-- <collision>
                <origin xyz="0.305417 -0.524138 -0.646947" rpy="0 0 0" />
                <geometry>
                    <mesh filename="${collision_central}" scale="${meshscale}" />
                </geometry>
            </collision> -->
            <inertial>
                <mass value="1" />
                <origin xyz="0 0 0" rpy="0 0 0" />
                <inertia ixx="1.0" ixy="0" ixz="0" iyy="1.0" iyz="0" izz="1.0" />
            </inertial>
        </link>


        <link name="backrest_link">
            <visual>
                <origin xyz="0.077317 -0.524138 -0.658821" rpy="0 0 0" />
                <geometry>
                    <mesh filename="${visual_backrest}" scale="${meshscale}" />
                </geometry>
                <material name="yellow_material" />
            </visual>
            <!-- <collision>
                <origin xyz="0.077317 -0.524138 -0.658821" rpy="0 0 0" />
                <geometry>
                    <mesh filename="${collision_superior}" scale="${meshscale}" />
                </geometry>
            </collision> -->
            <inertial>
                <mass value="1" />
                <origin xyz="0 0 0" rpy="0 0 0" />
                <inertia ixx="1" ixy="0" ixz="0" iyy="1" iyz="0" izz="1" />
            </inertial>
        </link>


        <joint name="base_to_support" type="prismatic">
            <parent link="base_link" />
            <child link="support_link" />
            <origin xyz="-0.0323729 0.0540746 0.555575" rpy="0 0 0" />
            <axis xyz="0 0 1" />
            <limit effort="1000" lower="0" upper="0.1" velocity="0.1" />
            <dynamics damping="0" friction="0" />
        </joint>

        <joint name="support_to_rot_y" type="revolute">
            <parent link="support_link" />
            <child link="seat_rot_y_link" />
            <origin xyz="0.014189 0.000075 0.125175" rpy="0 0 0" />
            <axis xyz="0 1 0" />
            <limit effort="1000" lower="-0.52" upper="0.52" velocity="1.0" />
            <dynamics damping="0" friction="0" />
        </joint>

        <joint name="rot_y_to_rot_x" type="revolute">
            <parent link="seat_rot_y_link" />
            <child link="seat_rot_x_link" />
            <origin xyz="0 0 0" rpy="0 0 0" />
            <axis xyz="1 0 0" />
            <limit effort="1000" lower="-0.349066" upper="0.349066" velocity="1.0" />
            <dynamics damping="0" friction="0" />

        </joint>

        <joint name="rot_combined_to_seat" type="prismatic">
            <parent link="seat_rot_x_link" />
            <child link="seat_link" />
            <origin xyz="0 0 0" rpy="0 0 0" />
            <axis xyz="1 0 0" />
            <limit effort="1000" lower="-0.12" upper="0.13445" velocity="0.1" />


        </joint>

        <joint name="seat_to_backrest" type="revolute">
            <parent link="seat_link" />
            <child link="backrest_link" />
            <origin xyz="0.2281 0 0.011874" rpy="0 0 0" />
            <axis xyz="0 1 0" />
            <limit effort="1000" lower="-1.48353" upper="0.610865" velocity="0.1" />
            <dynamics damping="0" friction="0" />
        </joint>

        <joint name="world_to_base" type="fixed">
            <parent link="world" />
            <child link="base_link" />
        </joint>

        <!--

    <transmission name="base_to_support_trans">
        <type>transmission_interface/SimpleTransmission</type>
        <actuator name="base_to_support_motor">
            <mechanicalReduction>1</mechanicalReduction>
        </actuator>
        <joint name="base_to_support">
            <hardwareInterface>hardware_interface/PositionJointInterface</hardwareInterface>
        </joint>
    </transmission>

    <transmission name="support_to_rot_y_trans">
        <type>transmission_interface/SimpleTransmission</type>
        <actuator name="support_to_rot_y_motor">
            <mechanicalReduction>1</mechanicalReduction>
        </actuator>
        <joint name="support_to_rot_y">
            <hardwareInterface>hardware_interface/PositionJointInterface</hardwareInterface>
        </joint>
    </transmission>

    <transmission name="roty_to_rotx_trans">
        <type>transmission_interface/SimpleTransmission</type>
        <actuator name="roty_to_rotx_motor">
            <mechanicalReduction>1</mechanicalReduction>
        </actuator>
        <joint name="rot_y_to_rot_x">
            <hardwareInterface>hardware_interface/PositionJointInterface</hardwareInterface>
        </joint>
    </transmission>

    <transmission name="rot_to_seat_trans">
        <type>transmission_interface/SimpleTransmission</type>
        <actuator name="rot_to_seat_motor">
            <mechanicalReduction>1</mechanicalReduction>
        </actuator>
        <joint name="rot_combined_to_seat">
            <hardwareInterface>hardware_interface/PositionJointInterface</hardwareInterface>
        </joint>
    </transmission>

    <transmission name="seat_to_backrest_trans">
        <type>transmission_interface/SimpleTransmission</type>
        <actuator name="seat_to_backrest_motor">
            <mechanicalReduction>1</mechanicalReduction>
        </actuator>
        <joint name="seat_to_backrest">
            <hardwareInterface>hardware_interface/PositionJointInterface</hardwareInterface>
        </joint>
    </transmission>
 
-->

        <ros2_control name="GazeboSystem" type="system">
            <hardware>
                <plugin>gz_ros2_control/GazeboSimSystem</plugin>
            </hardware>
            <joint name="base_to_support">
                <command_interface name="velocity" />
                <command_interface name="position" />
                    <param name="min">0</param>
                    <param name="max">0.1</param> 
                <state_interface name="position">
                    <param name="initial_value">0.01</param>
                </state_interface>
                <state_interface name="velocity" />
            </joint>
            <joint name="support_to_rot_y">
                <command_interface name="velocity" />
                <command_interface name="position" />
                    <param name="min">-0.52</param>
                    <param name="max">0.52</param> 
                <state_interface name="position" />
                <state_interface name="velocity" />
            </joint>
            <joint name="rot_y_to_rot_x">
                <command_interface name="velocity" />
                <command_interface name="position" />
                    <param name="min">-0.3490660</param>
                    <param name="max">0.3490660</param>
                <state_interface name="position" />
                <state_interface name="velocity" />
            </joint>
            <joint name="rot_combined_to_seat">
                <command_interface name="velocity" />
                <command_interface name="position" />
                    <param name="min">-0.12</param>
                    <param name="max">0.13445</param> 
                <state_interface name="position" />
                <state_interface name="velocity" />
            </joint>
            <joint name="seat_to_backrest">
                <command_interface name="velocity" />
                <command_interface name="position" />
                    <param name="min">-1.48353</param>
                    <param name="max">0.610865</param>
                <state_interface name="position" />
                <state_interface name="velocity" />
            </joint>
        </ros2_control>

        <gazebo>
            <plugin name="gz_ros2_control::GazeboSimROS2ControlPlugin"
                filename="libgz_ros2_control-system.so">
                <parameters>$(find opt_description)/config/controller_config.yaml</parameters>
            </plugin>
        </gazebo>
    </xacro:macro>
</robot>
